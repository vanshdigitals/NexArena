rules_version = '2';

/**
 * Firestore Security Rules for NexArena
 *
 * Collections:
 *   zones/current    — real-time crowd density per stadium zone
 *   alerts/{alertId} — operator-issued alerts broadcast to fans
 *   events/active    — active event metadata
 *
 * Roles:
 *   Authenticated users — can read all venue data
 *   Admins (custom claim) — can write zone data, alerts, and events
 *   Public — can read event metadata only
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Zone Density ──────────────────────────────────────────────────
    // Read: any authenticated user (fans need live density data)
    // Write: admin operators only (via custom claim admin == true)
    match /zones/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.admin == true;
    }

    // ── Alerts ────────────────────────────────────────────────────────
    // Read: any authenticated user (fans see safety alerts)
    // Write: admin operators only
    // Validate: severity must be one of info/warning/critical
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.token.admin == true
                    && request.resource.data.message is string
                    && request.resource.data.severity in ['info', 'warning', 'critical']
                    && request.resource.data.zone is string;
      allow update, delete: if request.auth != null
                            && request.auth.token.admin == true;
    }

    // ── Events ────────────────────────────────────────────────────────
    // Read: public (event info is non-sensitive)
    // Write: admin operators only
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.admin == true;
    }

    // ── Default deny ──────────────────────────────────────────────────
    // Any collection not explicitly matched above is denied
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
